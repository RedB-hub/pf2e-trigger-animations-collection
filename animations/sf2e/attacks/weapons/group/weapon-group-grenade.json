        "script": {
          "value": "/**\n * @param {unknown[]} inputs\n * @returns {boolean} to break out current process\n * @returns {{type: EntryType; value: unknown}[]}\n *\n * @example\n * const x = inputs[0];\n * const y = inputs[1];\n * return [{type: \"number\", value: x + y}];\n */\nconst options = inputs[0];\nconst item = inputs[1];\nconst slugs = new Set([{slug: \"degradation-grenade\", type:\"degradation\"},{slug: \"electromag-grenade\", type:\"electromag\"},{slug: \"flash-grenade\", type:\"flash\"}, {slug: \"frag-grenade\", type:\"frag\"}, {slug: \"incendiary-grenade\", type:\"incendiary\"}, {slug: \"maratan-headache\", type:\"maratan\"}, {slug: \"ossifying-grenade\", type:\"ossifying\"}, {slug: \"smoke-grenade\", type:\"smoke\"}]);\n\nlet type = \"default\";\nslugs.forEach((slug) => {\n  const slugOption = options.find(op => op.startsWith(\"origin:item:slug:\" + slug.slug + \"-\"));\n  if (slugOption)\n    type = slug.type;\n});\nreturn [{type: \"text\", value: type}];"
        },
        "Qk49zspQP2EaGLJl": {
