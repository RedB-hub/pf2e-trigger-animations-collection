          }
        }
      },
      "inputs": {
        "2vXIlxTwsJ7AwF3e": {
          "connection": "issvyytzK9Jrg9PG:outputs:entry"
        },
        "script": {
          "value": "/**\n * @param {unknown[]} inputs\n * @returns {boolean} to break out current process\n * @returns {{type: EntryType; value: unknown}[]}\n *\n * @example\n * const x = inputs[0];\n * const y = inputs[1];\n * return [{type: \"number\", value: x + y}];\n */\nconst type = inputs[0];\nlet sfx;\n\nswitch (type) {\n  case \"degradation\":\n    sfx = \"ggg-sfx.ranged.bomb.acid.01\";\n    break;\n  case \"incendiary\":\n    sfx = \"ggg-sfx.magic.fire.impact.flame.02\";\n    break;\n  case \"flash\":\n    sfx = \"ggg-sfx.magic.divine.nova.01.01\";\n    break;\n  case \"frag\":\n    sfx = \"ggg-sfx.ranged.bomb.explosion.01\";\n    break;\n  case \"maratan\":\n    sfx = \"ggg-sfx.ranged.bomb.poison.01\";\n    break;\n  case \"electromag\":\n    sfx = \"ggg-sfx.ranged.bomb.electricity.01\";\n    break;\n  case \"ossifying\":\n    sfx = \"ggg-sfx.magic.occult.impact.general.02.02\";\n    break;\n  case \"smoke\":\n    sfx = \"ggg-sfx.ranged.bomb.explosion.01\";\n    break;\n  default:\n    sfx = \"ggg-sfx.ranged.bomb.break.01\";\n    break;\n}\n\nreturn [{type: \"text\", value: sfx}];"
        }
      },
      "outs": {
        "out": {
          "connection": "U0J4Ln92UEyHDqzK:ins:in"
        }
      }
    },
