        "script": {
          "value": "/**\n * @param {unknown[]} inputs\n * @returns {boolean} to break out current process\n * @returns {{type: EntryType; value: unknown}[]}\n *\n * @example\n * const x = inputs[0];\n * const y = inputs[1];\n * return [{type: \"number\", value: x + y}];\n */\nconst options = inputs[0];\nconst option = options.find(op => op.startsWith(\"item:hands-held:\"));\nconst hands= option.slice(-1);\nlet delay=-1200;\nif (hands == 2)\n  delay=-1300\nreturn [{type: \"number\", value: hands}, {type: \"number\", value: delay}];"
